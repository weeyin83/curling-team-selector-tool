{
    "$schema": "https://json.schemastore.org/staticwebapp.config.json",

    "routes": [
        { "route": "/robots.txt",  "rewrite": "/robots.txt",  "headers": { "Content-Type": "text/plain; charset=utf-8" } },
        { "route": "/sitemap.xml", "rewrite": "/sitemap.xml", "headers": { "Content-Type": "application/xml; charset=utf-8" } }
    ],

    "mimeTypes": {
        ".txt": "text/plain",
        ".xml": "application/xml",
        ".svg": "image/svg+xml",
        ".webmanifest": "application/manifest+json",
        ".json": "application/json"
    },

    "responseOverrides": {
        "404": {
            "rewrite": "/404.html",
            "statusCode": 404
        }
    },

    "globalHeaders": {
        "X-Content-Type-Options": "nosniff",
        "Referrer-Policy": "strict-origin-when-cross-origin",
        "Permissions-Policy": "geolocation=(), camera=(), microphone=(), payment=()"
    }
}
